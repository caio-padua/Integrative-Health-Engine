# ─── PADCOM — Variáveis de ambiente de pagamentos ──────────────────────────────
# Copie para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env com valores reais.

# ─── Geral ────────────────────────────────────────────────────────────────────
API_PUBLIC_URL=https://seu-replit-slug.replit.app/api
FRONTEND_URL=https://seu-replit-slug.replit.app
DEFAULT_GATEWAY=asaas   # asaas | mercadopago | stripe | infinitpay

# ─── Asaas ────────────────────────────────────────────────────────────────────
# Obtenha em: https://app.asaas.com/config/api
ASAAS_API_KEY=
ASAAS_SANDBOX=true   # mude para false em produção

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # configurado no dashboard Stripe → Webhooks

# Prices IDs criados no dashboard Stripe (um por plano+ciclo)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# ─── InfinitPay ───────────────────────────────────────────────────────────────
# Obtenha em: https://portal.infinitepay.io → Desenvolvedor → API Keys
INFINITPAY_CLIENT_ID=
INFINITPAY_CLIENT_SECRET=
INFINITPAY_WEBHOOK_SECRET=   # string configurada no portal da InfinitPay

# ─── Banco (quando backend real estiver pronto) ───────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/padcom
